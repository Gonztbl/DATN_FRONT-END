@startuml UC76_AdminQuanLyMerchant
title Admin quản lý Merchant

autonumber "<b>[00]</b>"
skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam defaultFontSize 20
skinparam titleFontSize 26
skinparam sequenceFontSize 19
skinparam sequenceMessageFontSize 20
skinparam sequenceActorFontSize 20
skinparam sequenceParticipantFontSize 20
skinparam noteFontSize 18
skinparam sequenceArrowFontSize 20
skinparam sequence {
    ParticipantPadding 30
    LifeLinePadding 20
    MessagePadding 10
}

actor "Admin" as Admin
boundary ":MerchantManagementUI" as UI
control ":MerchantController" as CTRL
entity ":Merchant" as ENT
database ":CSDL" as DB

Admin -> UI : Truy cập quản lý Merchant
activate UI

UI -> CTRL : getRestaurantOwners(params)
activate CTRL
CTRL -> ENT : GET /api/admin/restaurant-owners
activate ENT
ENT -> DB : Truy vấn danh sách Merchant
activate DB
DB --> ENT : Danh sách Merchant[]
deactivate DB
ENT --> CTRL : Trả về dữ liệu
deactivate ENT
CTRL --> UI : Hiển thị danh sách nhà hàng đối tác
deactivate CTRL

Admin -> UI : Nhấn toggle trạng thái Merchant
UI -> CTRL : updateMerchantStatus(id, status)
activate CTRL
CTRL -> ENT : PUT /api/admin/merchants/{id}/status
activate ENT
ENT -> DB : Cập nhật trạng thái Merchant
activate DB
DB --> ENT : 200 OK
deactivate DB
ENT --> CTRL : Thành công
deactivate ENT
CTRL --> UI : Cập nhật thành công
deactivate CTRL
UI --> Admin : Cập nhật UI trạng thái mới

deactivate UI
@enduml
