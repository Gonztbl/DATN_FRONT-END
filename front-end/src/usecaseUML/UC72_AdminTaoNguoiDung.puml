@startuml UC72_AdminTaoNguoiDung
title Admin khởi tạo tài khoản người dùng

autonumber "<b>[00]</b>"
skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam defaultFontSize 20
skinparam titleFontSize 26
skinparam sequenceFontSize 19
skinparam sequenceMessageFontSize 20
skinparam sequenceActorFontSize 20
skinparam sequenceParticipantFontSize 20
skinparam noteFontSize 18
skinparam sequenceArrowFontSize 20
skinparam sequence {
    ParticipantPadding 30
    LifeLinePadding 20
    MessagePadding 10
}

actor "Admin" as Admin
boundary ":AdminUserCreateUI" as UI
control ":RegisterController" as CTRL
entity ":Account" as ENT
database ":CSDL" as DB

Admin -> UI : Truy cập trang tạo tài khoản
activate UI
UI --> Admin : Hiển thị form tạo tài khoản

Admin -> UI : Nhập UserName, FullName, Email, Phone, Password, Role
Admin -> UI : Nhấn "Tạo tài khoản"

UI -> UI : validate() form (Client-side)

UI -> CTRL : adminCreateUser(payload) hoặc adminRegister(payload)
activate CTRL
CTRL -> ENT : POST /api/admin/users (role=USER) hoặc POST /api/auth/admin/register (role khác)
activate ENT
ENT -> DB : Tạo tài khoản mới trong bảng Account
activate DB
DB --> ENT : 201 Success {accountNumber}
deactivate DB
ENT --> CTRL : Trả về dữ liệu response
deactivate ENT
CTRL --> UI : Thành công
deactivate CTRL

UI --> Admin : Hiển thị "Tạo tài khoản thành công!"
UI --> Admin : Chuyển hướng về trang Quản lý người dùng

deactivate UI
@enduml
