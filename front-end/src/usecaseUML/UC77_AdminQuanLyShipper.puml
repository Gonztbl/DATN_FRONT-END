@startuml UC77_AdminQuanLyShipper
title Admin quản lý Shipper

autonumber "<b>[00]</b>"
skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam defaultFontSize 20
skinparam titleFontSize 26
skinparam sequenceFontSize 19
skinparam sequenceMessageFontSize 20
skinparam sequenceActorFontSize 20
skinparam sequenceParticipantFontSize 20
skinparam noteFontSize 18
skinparam sequenceArrowFontSize 20
skinparam sequence {
    ParticipantPadding 30
    LifeLinePadding 20
    MessagePadding 10
}

actor "Admin" as Admin
boundary ":ShipperManagementUI" as UI
control ":ShipperController" as CTRL
entity ":Shipper" as ENT
database ":CSDL" as DB

Admin -> UI : Truy cập quản lý Shipper
activate UI

UI -> CTRL : getAllShippers()
activate CTRL
CTRL -> ENT : GET /api/admin/shippers
activate ENT
ENT -> DB : Truy vấn danh sách Shipper
activate DB
DB --> ENT : Danh sách Shipper[]
deactivate DB
ENT --> CTRL : Trả về dữ liệu
deactivate ENT
CTRL --> UI : Hiển thị danh sách shipper
deactivate CTRL

Admin -> UI : Nhấn "View Details" tại một Shipper
UI -> CTRL : getShipperDetail(id)
activate CTRL
CTRL -> ENT : GET /api/admin/shippers/{id}
activate ENT
ENT -> DB : Truy vấn hồ sơ & phương tiện
activate DB
DB --> ENT : Profile, VehicleInfo
deactivate DB
ENT --> CTRL : Trả về chi tiết
deactivate ENT
CTRL --> UI : Hiển thị chi tiết Shipper
deactivate CTRL
UI --> Admin : Xem hồ sơ & Thông tin phương tiện

deactivate UI
@enduml
