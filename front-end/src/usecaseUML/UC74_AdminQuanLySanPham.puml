@startuml UC74_AdminQuanLySanPham
title Admin quản lý sản phẩm

autonumber "<b>[00]</b>"
skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam defaultFontSize 20
skinparam titleFontSize 26
skinparam sequenceFontSize 19
skinparam sequenceMessageFontSize 20
skinparam sequenceActorFontSize 20
skinparam sequenceParticipantFontSize 20
skinparam noteFontSize 18
skinparam sequenceArrowFontSize 20
skinparam sequence {
    ParticipantPadding 30
    LifeLinePadding 20
    MessagePadding 10
}

actor "Admin" as Admin
boundary ":AdminProductUI" as UI
control ":ProductController" as CTRL
entity ":Product" as ENT
database ":CSDL" as DB

Admin -> UI : Truy cập quản lý sản phẩm
activate UI

UI -> CTRL : Tải Categories & Restaurants & Products
activate CTRL
CTRL -> ENT : GET /api/admin/categories & /api/admin/restaurants & /api/admin/products
activate ENT
ENT -> DB : Truy vấn danh sách
activate DB
DB --> ENT : Categories[], Restaurants[], Products[] & Total
deactivate DB
ENT --> CTRL : Trả về dữ liệu
deactivate ENT
CTRL --> UI : Hiển thị bảng sản phẩm & Bộ lọc
deactivate CTRL

Admin -> UI : Nhấn "Thêm món mới" hoặc "Chỉnh sửa"
UI --> Admin : Hiển thị Modal Form
Admin -> UI : Nhập Tên, Giá, Ảnh, Danh mục, Cửa hàng
Admin -> UI : Nhấn "Lưu thay đổi"

UI -> CTRL : createProduct hoặc updateProduct
activate CTRL
CTRL -> ENT : POST /api/admin/products hoặc PUT /api/admin/products/{id}
activate ENT
ENT -> DB : Tạo mới hoặc Cập nhật sản phẩm
activate DB
DB --> ENT : Thành công
deactivate DB
ENT --> CTRL : Trả về kết quả
deactivate ENT
CTRL --> UI : Thành công & Đóng Modal
deactivate CTRL

Admin -> UI : Nhấn Icon "Xem chi tiết" sản phẩm
UI -> CTRL : getProductDetail(id)
activate CTRL
CTRL -> ENT : GET /api/admin/products/{id}
activate ENT
ENT -> DB : Truy vấn chi tiết sản phẩm
activate DB
DB --> ENT : Product Detail (ảnh, rating, nhà hàng)
deactivate DB
ENT --> CTRL : Trả về chi tiết
deactivate ENT
CTRL --> UI : Hiển thị Modal xem chi tiết
deactivate CTRL

Admin -> UI : Nhấn Toggle trạng thái (Bật/Tắt)
UI -> CTRL : updateProductStatus(id, newStatus)
activate CTRL
CTRL -> ENT : PUT /api/admin/products/{id}/status
activate ENT
ENT -> DB : Cập nhật trạng thái available/unavailable
activate DB
DB --> ENT : Thành công
deactivate DB
ENT --> CTRL : Updated
deactivate ENT
CTRL --> UI : Cập nhật UI
deactivate CTRL

deactivate UI
@enduml
