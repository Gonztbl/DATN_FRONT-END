@startuml UC64_AdminQuanLyNhaHang
title Admin quản lý nhà hàng

autonumber "<b>[00]</b>"
skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam defaultFontSize 20
skinparam titleFontSize 26
skinparam sequenceFontSize 19
skinparam sequenceMessageFontSize 20
skinparam sequenceActorFontSize 20
skinparam sequenceParticipantFontSize 20
skinparam noteFontSize 18
skinparam sequenceArrowFontSize 20
skinparam sequence {
    ParticipantPadding 30
    LifeLinePadding 20
    MessagePadding 10
}

actor "Admin" as Admin
boundary ":AdminRestaurantUI" as UI
control ":RestaurantController" as CTRL
entity ":Restaurant" as ENT
database ":CSDL" as DB

Admin -> UI : Truy cập quản lý nhà hàng
activate UI

UI -> CTRL : Tải danh sách Owners & Restaurants
activate CTRL
CTRL -> ENT : GET /api/userManager/all & GET /api/admin/restaurants
activate ENT
ENT -> DB : Truy vấn dữ liệu
activate DB
DB --> ENT : Danh sách Owners[] & Restaurant[]
deactivate DB
ENT --> CTRL : Trả về dữ liệu
deactivate ENT
CTRL --> UI : Hiển thị bảng nhà hàng & Bộ lọc
deactivate CTRL

Admin -> UI : Nhấn "Xuất dữ liệu"
UI -> CTRL : exportRestaurants(params)
activate CTRL
CTRL -> ENT : GET /api/admin/restaurants/export
activate ENT
ENT -> DB : Xuất dữ liệu
activate DB
DB --> ENT : Blob File
deactivate DB
ENT --> CTRL : Trả về file
deactivate ENT
CTRL --> UI : Tạo URL & Tải file
deactivate CTRL
UI --> Admin : Tải file về máy tính

Admin -> UI : Nhấn "Thêm nhà hàng" hoặc "Chỉnh sửa"
UI --> Admin : Hiển thị Modal Form
Admin -> UI : Nhập thông tin & Nhấn "Lưu"

UI -> CTRL : checkRestaurantName(name)
activate CTRL
CTRL -> ENT : GET /api/admin/restaurants/check-name?name=...
activate ENT
ENT -> DB : Kiểm tra trùng tên
activate DB
DB --> ENT : {exists: true/false}
deactivate DB
ENT --> CTRL : Trả về kết quả
deactivate ENT
CTRL --> UI : Tên hợp lệ
deactivate CTRL

UI -> CTRL : createRestaurant hoặc updateRestaurant
activate CTRL
CTRL -> ENT : POST /api/admin/restaurants hoặc PUT /api/admin/restaurants/{id}
activate ENT
ENT -> DB : Tạo mới hoặc Cập nhật
activate DB
DB --> ENT : Thành công
deactivate DB
ENT --> CTRL : Trả về kết quả
deactivate ENT
CTRL --> UI : Thành công & Đóng Modal
deactivate CTRL

Admin -> UI : Nhấn "Xóa nhà hàng"
UI -> UI : Hiển thị Confirm
Admin -> UI : Xác nhận xóa

UI -> CTRL : deleteRestaurant(id)
activate CTRL
CTRL -> ENT : DELETE /api/admin/restaurants/{id}
activate ENT
ENT -> DB : Xóa nhà hàng
activate DB
DB --> ENT : Success
deactivate DB
ENT --> CTRL : Deleted
deactivate ENT
CTRL --> UI : Reload danh sách
deactivate CTRL

deactivate UI
@enduml
