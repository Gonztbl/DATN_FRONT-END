@startuml UC79_AdminTaiChinh
title Admin xem Dashboard tài chính

autonumber "<b>[00]</b>"
skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam defaultFontSize 20
skinparam titleFontSize 26
skinparam sequenceFontSize 19
skinparam sequenceMessageFontSize 20
skinparam sequenceActorFontSize 20
skinparam sequenceParticipantFontSize 20
skinparam noteFontSize 18
skinparam sequenceArrowFontSize 20
skinparam sequence {
    ParticipantPadding 30
    LifeLinePadding 20
    MessagePadding 10
}

actor "Admin" as Admin
boundary ":AdminFinanceUI" as UI
control ":FinanceController" as CTRL
entity ":Finance" as ENT
database ":CSDL" as DB

Admin -> UI : Xem Dashboard Tài chính
activate UI

UI -> CTRL : getSystemFinancialSummary()
activate CTRL
CTRL -> ENT : GET /api/admin/finance/summary
activate ENT
ENT -> DB : Truy vấn tổng hợp tài chính
activate DB
DB --> ENT : {totalBalance, totalTransactions, revenue}
deactivate DB
ENT --> CTRL : Trả về dữ liệu tài chính
deactivate ENT
CTRL --> UI : Hiển thị biểu đồ và con số
deactivate CTRL

UI --> Admin : Xem báo cáo doanh thu toàn hệ thống

deactivate UI
@enduml
