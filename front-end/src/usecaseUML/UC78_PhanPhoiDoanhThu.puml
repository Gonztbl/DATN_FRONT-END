@startuml UC78_PhanPhoiDoanhThu
title Phân phối doanh thu khi giao hàng thành công

autonumber "<b>[00]</b>"
skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam defaultFontSize 20
skinparam titleFontSize 26
skinparam sequenceFontSize 19
skinparam sequenceMessageFontSize 20
skinparam sequenceActorFontSize 20
skinparam sequenceParticipantFontSize 20
skinparam noteFontSize 18
skinparam sequenceArrowFontSize 20
skinparam sequence {
    ParticipantPadding 30
    LifeLinePadding 20
    MessagePadding 10
}

actor "Shipper" as Shipper
boundary ":OrderUI" as UI
control ":OrderController" as CTRL
entity ":Wallet" as ENT
database ":CSDL" as DB

Shipper -> UI : Nhấn "Đã giao hàng"
activate UI

UI -> CTRL : PUT /api/shipper/orders/{id}/delivered
activate CTRL
CTRL -> ENT : Cập nhật trạng thái đơn hàng
activate ENT
ENT -> DB : Update Order Status = COMPLETED
activate DB
DB --> ENT : Thành công
deactivate DB

ENT -> DB : Cộng 95% vào Ví Nhà hàng
activate DB
DB --> ENT : Cập nhật xong
deactivate DB

ENT -> DB : Cộng 5% vào Ví Shipper
activate DB
DB --> ENT : Cập nhật xong
deactivate DB

ENT --> CTRL : Phân phối doanh thu hoàn tất
deactivate ENT
CTRL --> UI : 200 OK {payout: SUCCESS}
deactivate CTRL

UI --> Shipper : Hiển thị giao hàng thành công

deactivate UI
@enduml
