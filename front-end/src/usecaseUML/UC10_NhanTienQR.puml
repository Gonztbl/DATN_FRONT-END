@startuml UC10_NhanTienQR
title UC10 - Nhận tiền qua mã QR (Receive Money)

autonumber "<b>[00]</b>"
skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam defaultFontSize 20
skinparam titleFontSize 26
skinparam sequenceFontSize 19
skinparam sequenceMessageFontSize 20
skinparam sequenceActorFontSize 20
skinparam sequenceParticipantFontSize 20
skinparam noteFontSize 18
skinparam sequenceArrowFontSize 20
skinparam sequence {
    ParticipantPadding 30
    LifeLinePadding 20
    MessagePadding 10
}

actor "Người nhận" as User
boundary ":ReceiveMoneyUI" as UI
control ":WalletController" as CTRL
entity ":QRService" as QRS
entity ":Profile" as API
database ":CSDL" as DB

User -> UI : Truy cập trang Nhận tiền
activate UI

UI -> CTRL : Lấy Profile & Wallet Info
activate CTRL
CTRL -> API : GET /api/users/profile
activate API
API -> DB : Truy vấn thông tin
activate DB
DB --> API : Profile Data
deactivate DB
API --> CTRL : Dữ liệu đầy đủ
deactivate API
CTRL --> UI : Hiển thị tên & ID Ví
deactivate CTRL

UI -> QRS : Lấy mã QR mặc định (GET /api/qr/wallet)
activate QRS
QRS --> UI : QR Base64 Image
deactivate QRS

alt Nhập số tiền nhận (Tùy chọn)
    User -> UI : Nhập số tiền nhận cụ thể (Set Amount)
    UI -> QRS : Yêu cầu tạo QR kèm tiền (GET /api/qr/wallet?amount=...)
    activate QRS
    QRS --> UI : QR Base64 Image mới
    deactivate QRS
end

UI --> User : Hiển thị mã QR lên màn hình

loop Định kỳ 5s cập nhật
    UI -> CTRL : Lấy các giao dịch đến mới nhất
    activate CTRL
    CTRL -> API : GET /api/transactions/incoming
    activate API
    API -> DB : Kiểm tra biến động số dư
    activate DB
    DB --> API : Danh sách giao dịch mới
    deactivate DB
    API --> CTRL : [TX1, TX2, ...]
    deactivate API
    CTRL --> UI : Cập nhật danh sách "Tiền nhận gần đây"
    deactivate CTRL
    
    alt Có giao dịch thành công mới
        UI --> User : Thông báo "Bạn vừa nhận được {Amount}đ!"
    end
end

deactivate UI

@enduml
