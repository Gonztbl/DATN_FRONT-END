@startuml UC60_AdminTopup
title Admin nạp tiền vào ví

autonumber "<b>[00]</b>"
skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam defaultFontSize 20
skinparam titleFontSize 26
skinparam sequenceFontSize 19
skinparam sequenceMessageFontSize 20
skinparam sequenceActorFontSize 20
skinparam sequenceParticipantFontSize 20
skinparam noteFontSize 18
skinparam sequenceArrowFontSize 20
skinparam sequence {
    ParticipantPadding 30
    LifeLinePadding 20
    MessagePadding 10
}

actor "Admin" as Admin
boundary ":AdminWalletUI" as UI
control ":WalletController" as CTRL
entity ":Transaction" as ENT
database ":CSDL" as DB

Admin -> UI : Chọn ví, nhấn "Topup"
activate UI

UI --> Admin : Hiển thị Modal Topup
Admin -> UI : Nhập số tiền (amount), nhấn "Confirm"

UI -> UI : Validate (amount > 0)

UI -> CTRL : adminTopup({walletId, amount})
activate CTRL
CTRL -> ENT : POST /api/admin/wallets/topup
activate ENT
ENT -> DB : Cộng tiền vào ví & Tạo Transaction (ADMIN_TOPUP)
activate DB
DB --> ENT : 200 OK {success: true, newBalance}
deactivate DB
ENT --> CTRL : Đã tạo giao dịch
deactivate ENT
CTRL --> UI : Thành công
deactivate CTRL

UI --> Admin : Hiển thị "Nạp tiền thành công", refresh danh sách

deactivate UI
@enduml
