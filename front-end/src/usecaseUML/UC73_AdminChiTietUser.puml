@startuml UC73_AdminChiTietUser
title Admin xem chi tiết hồ sơ người dùng

autonumber "<b>[00]</b>"
skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam defaultFontSize 20
skinparam titleFontSize 26
skinparam sequenceFontSize 19
skinparam sequenceMessageFontSize 20
skinparam sequenceActorFontSize 20
skinparam sequenceParticipantFontSize 20
skinparam noteFontSize 18
skinparam sequenceArrowFontSize 20
skinparam sequence {
    ParticipantPadding 30
    LifeLinePadding 20
    MessagePadding 10
}

actor "Admin" as Admin
boundary ":UserDetailUI" as UI
control ":UserDetailController" as CTRL
entity ":Account" as ENT
database ":CSDL" as DB

Admin -> UI : Truy cập chi tiết người dùng
activate UI

UI -> CTRL : Tải dữ liệu User, Embeddings, Wallets, Transactions
activate CTRL
CTRL -> ENT : GET /api/userManager/all & GET /api/face/list/{userId} & GET /api/admin/wallets & GET /api/admin/transactions
activate ENT
ENT -> DB : Truy vấn dữ liệu liên quan theo userId
activate DB
DB --> ENT : User, Embeddings[], Wallets[], Transactions[]
deactivate DB
ENT --> CTRL : Trả về dữ liệu tổng hợp
deactivate ENT
CTRL --> UI : Cập nhật states
deactivate CTRL

UI --> Admin : Hiển thị Chi tiết (Thông tin chung, Ví, Giao dịch)

Admin -> UI : Nhấn "Chỉnh sửa hồ sơ"
UI --> Admin : Mở Modal chỉnh sửa
Admin -> UI : Thay đổi dữ liệu & Submit

UI -> CTRL : updateUser(id, payload)
activate CTRL
CTRL -> ENT : PUT /api/userManager/update/{id}
activate ENT
ENT -> DB : Cập nhật thông tin Account
activate DB
DB --> ENT : Thành công
deactivate DB
ENT --> CTRL : Updated
deactivate ENT
CTRL --> UI : Cập nhật state & Đóng Modal
deactivate CTRL
UI --> Admin : Thông báo thành công

Admin -> UI : Nhấn "Xóa người dùng"
UI -> UI : Hiển thị xác nhận
Admin -> UI : Xác nhận xóa

UI -> CTRL : deleteUser(id)
activate CTRL
CTRL -> ENT : DELETE /api/admin/users/{id}
activate ENT
ENT -> DB : Xóa tài khoản
activate DB
DB --> ENT : OK
deactivate DB
ENT --> CTRL : Deleted
deactivate ENT
CTRL --> UI : OK
deactivate CTRL
UI --> Admin : Chuyển hướng về danh sách người dùng

Admin -> UI : Nhấn "Thêm khuôn mặt mới"
UI --> Admin : Chuyển hướng /admin/users/{id}/register-face

Admin -> UI : Nhấn "Kiểm tra xác thực"
UI --> Admin : Chuyển hướng /admin/users/{id}/verify-face

deactivate UI
@enduml
