@startuml UC21_AdminQuanLyNguoiDung
title Admin quản lý người dùng

autonumber "<b>[00]</b>"
skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam defaultFontSize 20
skinparam titleFontSize 26
skinparam sequenceFontSize 19
skinparam sequenceMessageFontSize 20
skinparam sequenceActorFontSize 20
skinparam sequenceParticipantFontSize 20
skinparam noteFontSize 18
skinparam sequenceArrowFontSize 20
skinparam sequence {
    ParticipantPadding 30
    LifeLinePadding 20
    MessagePadding 10
}

actor "Admin" as Admin
boundary ":UserManageUI" as UI
control ":UserAdminController" as CTRL
entity ":Account" as ENT
database ":CSDL" as DB

Admin -> UI : Truy cập quản lý người dùng
activate UI

UI -> CTRL : getAllUsers()
activate CTRL
CTRL -> ENT : GET /api/userManager/all
activate ENT
ENT -> DB : Truy vấn All Users từ bảng Account
activate DB
DB --> ENT : Danh sách Account[] (ID, Role, Status)
deactivate DB
ENT --> CTRL : Trả về dữ liệu
deactivate ENT
CTRL --> UI : Hiển thị bảng người dùng
deactivate CTRL

Admin -> UI : Lọc theo từ khóa / Trạng thái / Vai trò
UI -> UI : filter() mảng users & phân trang Client-side
UI --> Admin : Hiển thị danh sách kết quả phù hợp

Admin -> UI : Nhấn Toggle "Khóa/Mở khóa" tài khoản

UI -> CTRL : handleToggleLock(user)
activate CTRL
CTRL -> ENT : PUT /api/userManager/lock/{id} hoặc /unlock/{id}
activate ENT
ENT -> DB : Cập nhật trường 'active' theo ID
activate DB
DB --> ENT : Thành công
deactivate DB
ENT --> CTRL : Updated
deactivate ENT
CTRL --> UI : Cập nhật lại UI (setUsers cục bộ)
deactivate CTRL

Admin -> UI : Click vào dòng người dùng
UI --> Admin : Chuyển hướng navigate('/admin/users/{id}')

Admin -> UI : Nhấn "Tạo người dùng"
UI --> Admin : Chuyển hướng navigate('/admin/users/create')

deactivate UI

@enduml
