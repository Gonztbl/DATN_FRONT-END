@startuml UC71_AdminXacThucMat
title Admin kiểm tra xác thực khuôn mặt

autonumber "<b>[00]</b>"
skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam defaultFontSize 20
skinparam titleFontSize 26
skinparam sequenceFontSize 19
skinparam sequenceMessageFontSize 20
skinparam sequenceActorFontSize 20
skinparam sequenceParticipantFontSize 20
skinparam noteFontSize 18
skinparam sequenceArrowFontSize 20
skinparam sequence {
    ParticipantPadding 30
    LifeLinePadding 20
    MessagePadding 10
}

actor "Admin" as Admin
boundary ":AdminVerifyFaceUI" as UI
control ":FaceController" as CTRL
entity ":FaceEmbedding" as ENT
database ":CSDL" as DB

Admin -> UI : Truy cập kiểm tra xác thực khuôn mặt
activate UI

UI -> UI : Mở Camera (getUserMedia)
UI --> Admin : Hiển thị Stream Camera & Khung Oval

Admin -> UI : Nhấn "Thử nghiệm nhận diện"
UI -> UI : captureImage() chuyển frame thành Blob

UI -> CTRL : verifyFace(formData) [image: Blob, userId: id]
activate CTRL
CTRL -> ENT : POST /api/face/verify
activate ENT
ENT -> DB : So khớp embedding khuôn mặt
activate DB
DB --> ENT : Kết quả so khớp (PASS/FAIL, similarity)
deactivate DB
ENT --> CTRL : Trả về kết quả xác thực
deactivate ENT
CTRL --> UI : Kết quả (success/fail, confidence)
deactivate CTRL

UI --> Admin : Hiển thị kết quả xác thực (Khớp/Không khớp & % Tương đồng)

deactivate UI
@enduml
