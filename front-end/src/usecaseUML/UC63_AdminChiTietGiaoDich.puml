@startuml UC63_AdminChiTietGiaoDich
title Admin xem chi tiết giao dịch

autonumber "<b>[00]</b>"
skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam defaultFontSize 20
skinparam titleFontSize 26
skinparam sequenceFontSize 19
skinparam sequenceMessageFontSize 20
skinparam sequenceActorFontSize 20
skinparam sequenceParticipantFontSize 20
skinparam noteFontSize 18
skinparam sequenceArrowFontSize 20
skinparam sequence {
    ParticipantPadding 30
    LifeLinePadding 20
    MessagePadding 10
}

actor "Admin" as Admin
boundary ":AdminTransactionUI" as UI
control ":TransactionController" as CTRL
entity ":Transaction" as ENT
database ":CSDL" as DB

Admin -> UI : Nhấn "Chi tiết" tại một giao dịch
activate UI

UI -> UI : setSelectedTransaction(txn) từ danh sách đã tải
UI -> UI : setShowDetailModal(true)
UI --> Admin : Hiển thị Modal chi tiết giao dịch

UI --> Admin : Xem chi tiết (Transaction ID, Reference ID, Wallet ID, User ID, Amount, Type, Direction, Partner, Note, Status)

Admin -> UI : Nhấn "Đóng"
UI -> UI : setShowDetailModal(false)

deactivate UI
@enduml
