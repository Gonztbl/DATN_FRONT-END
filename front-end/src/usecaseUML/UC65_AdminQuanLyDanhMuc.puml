@startuml UC65_AdminQuanLyDanhMuc
title Admin quản lý danh mục

autonumber "<b>[00]</b>"
skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam defaultFontSize 20
skinparam titleFontSize 26
skinparam sequenceFontSize 19
skinparam sequenceMessageFontSize 20
skinparam sequenceActorFontSize 20
skinparam sequenceParticipantFontSize 20
skinparam noteFontSize 18
skinparam sequenceArrowFontSize 20
skinparam sequence {
    ParticipantPadding 30
    LifeLinePadding 20
    MessagePadding 10
}

actor "Admin" as Admin
boundary ":AdminCategoryUI" as UI
control ":CategoryController" as CTRL
entity ":Category" as ENT
database ":CSDL" as DB

Admin -> UI : Truy cập quản lý danh mục
activate UI

UI -> CTRL : getCategories(params)
activate CTRL
CTRL -> ENT : GET /api/admin/categories
activate ENT
ENT -> DB : Truy vấn danh sách danh mục
activate DB
DB --> ENT : Danh sách Category[] & Total
deactivate DB
ENT --> CTRL : Trả về dữ liệu
deactivate ENT
CTRL --> UI : Hiển thị bảng danh mục & Bộ lọc
deactivate CTRL

Admin -> UI : Nhấn "Xuất dữ liệu"
UI -> CTRL : exportCategories()
activate CTRL
CTRL -> ENT : GET /api/admin/categories/export
activate ENT
ENT -> DB : Xuất dữ liệu
activate DB
DB --> ENT : Blob File Export
deactivate DB
ENT --> CTRL : Trả về file
deactivate ENT
CTRL --> UI : Tạo URL & Tải file
deactivate CTRL
UI --> Admin : Tải file về máy tính

Admin -> UI : Nhấn "Thêm/Chỉnh sửa danh mục"
UI --> Admin : Hiển thị Modal Form
Admin -> UI : Nhập thông tin & Nhấn "Lưu"

UI -> CTRL : checkCategoryName(name)
activate CTRL
CTRL -> ENT : GET /api/admin/categories/check-name?name=...
activate ENT
ENT -> DB : Kiểm tra trùng tên danh mục
activate DB
DB --> ENT : {exists: true/false}
deactivate DB
ENT --> CTRL : Trả về kết quả
deactivate ENT
CTRL --> UI : Tên hợp lệ
deactivate CTRL

UI -> CTRL : createCategory hoặc updateCategory
activate CTRL
CTRL -> ENT : POST /api/admin/categories hoặc PUT /api/admin/categories/{id}
activate ENT
ENT -> DB : Tạo mới hoặc Cập nhật danh mục
activate DB
DB --> ENT : Thành công
deactivate DB
ENT --> CTRL : Trả về kết quả
deactivate ENT
CTRL --> UI : Thành công & Đóng Modal
deactivate CTRL

Admin -> UI : Nhấn "Xóa danh mục"
UI -> UI : Hiển thị Confirm
Admin -> UI : Xác nhận xóa

UI -> CTRL : deleteCategory(id)
activate CTRL
CTRL -> ENT : DELETE /api/admin/categories/{id}
activate ENT
ENT -> DB : Xóa danh mục
activate DB
DB --> ENT : Success
deactivate DB
ENT --> CTRL : Deleted
deactivate ENT
CTRL --> UI : Reload danh sách
deactivate CTRL

deactivate UI
@enduml
