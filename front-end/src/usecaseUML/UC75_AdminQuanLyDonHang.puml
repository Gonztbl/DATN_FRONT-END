@startuml UC75_AdminQuanLyDonHang
title Admin giám sát đơn hàng toàn hệ thống

autonumber "<b>[00]</b>"
skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam defaultFontSize 20
skinparam titleFontSize 26
skinparam sequenceFontSize 19
skinparam sequenceMessageFontSize 20
skinparam sequenceActorFontSize 20
skinparam sequenceParticipantFontSize 20
skinparam noteFontSize 18
skinparam sequenceArrowFontSize 20
skinparam sequence {
    ParticipantPadding 30
    LifeLinePadding 20
    MessagePadding 10
}

actor "Admin" as Admin
boundary ":ListOrderAdminUI" as UI
control ":OrderController" as CTRL
entity ":Order" as ENT
database ":CSDL" as DB

Admin -> UI : Truy cập danh sách đơn hàng
activate UI

UI -> CTRL : Tải Restaurants & Shippers & Orders
activate CTRL
CTRL -> ENT : GET /api/admin/restaurant-owners & /api/admin/shippers & /api/admin/orders
activate ENT
ENT -> DB : Truy vấn dữ liệu
activate DB
DB --> ENT : Restaurants[], Shippers[], Orders[]
deactivate DB
ENT --> CTRL : Trả về dữ liệu
deactivate ENT
CTRL --> UI : Hiển thị bảng quản lý đơn hàng
deactivate CTRL

Admin -> UI : Thay đổi bộ lọc (Ngày / Trạng thái / Nhà hàng / Shipper)
UI -> CTRL : getAllOrders(params)
activate CTRL
CTRL -> ENT : GET /api/admin/orders?filters
activate ENT
ENT -> DB : Truy vấn với điều kiện lọc
activate DB
DB --> ENT : Kết quả lọc
deactivate DB
ENT --> CTRL : Trả về dữ liệu
deactivate ENT
CTRL --> UI : Cập nhật danh sách
deactivate CTRL

Admin -> UI : Nhấn "Xem chi tiết" đơn hàng
UI --> Admin : Chuyển hướng /admin/orders/{id}

Admin -> UI : Nhấn "Xóa đơn hàng"
UI -> UI : Hiển thị cảnh báo "Xóa vĩnh viễn"
Admin -> UI : Xác nhận xóa

UI -> CTRL : deleteOrder(id)
activate CTRL
CTRL -> ENT : DELETE /api/admin/orders/{id}
activate ENT
ENT -> DB : Xóa đơn hàng
activate DB
DB --> ENT : Success
deactivate DB
ENT --> CTRL : Deleted
deactivate ENT
CTRL --> UI : Thông báo "Xóa thành công" & Refresh
deactivate CTRL

deactivate UI
@enduml
